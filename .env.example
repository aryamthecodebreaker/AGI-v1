# Server
PORT=3000
HOST=127.0.0.1

# Auth — if missing, a random one is generated and written to .env on first run
JWT_SECRET=

# Data / models
DATA_DIR=./data

# LLM backend: "gemini"      (default — Google Gemini API, works on any host)
#              "transformers" (local @huggingface/transformers, needs ~500MB on disk)
#              "scratch"      (from-scratch transformer, Step 11)
LLM_BACKEND=gemini

# For LLM_BACKEND=gemini, set this to a Gemini model ID:
#   gemini-2.5-flash-lite  (cheapest + fastest, default)
#   gemini-2.5-flash
#   gemini-2.5-pro
# For LLM_BACKEND=transformers, set to an HF model ID like:
#   HuggingFaceTB/SmolLM2-360M-Instruct
#   onnx-community/Qwen2.5-1.5B-Instruct
LLM_MODEL_ID=gemini-2.5-flash-lite

# Required when LLM_BACKEND=gemini. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Embedding model (local, ~90MB). Used regardless of LLM backend.
EMBED_MODEL_ID=Xenova/all-MiniLM-L6-v2

# Log level: trace|debug|info|warn|error
LOG_LEVEL=info
